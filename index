<style>
:root {
  --navy: #002B45;
  --blue: #0073CF;
  --cyan: #00A9E0;
  --digital: #00549F;
  --amber: #F0AB00;
  --red: #D52B1E;
  --light: #f4f8fb;
  --white: #ffffff;
  --text: #1a2535;
  --muted: #6b7f96;
  --border: #dce6ef;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
  width: 100%;
  height: 100%;
  font-family: 'DM Sans', sans-serif;
  background: var(--light);
  color: var(--text);
}

.wrapper {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* HEADER */
.header {
  background: var(--navy);
  padding: 14px 16px 0;
  flex-shrink: 0;
}

.header-top {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 12px;
}

.header-icon {
  width: 34px; height: 34px;
  background: rgba(255,255,255,0.12);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1rem;
  flex-shrink: 0;
}

.header-title {
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--white);
  letter-spacing: -0.01em;
  line-height: 1.2;
}

.header-sub {
  font-size: 0.72rem;
  color: rgba(255,255,255,0.6);
  margin-top: 2px;
}

/* MONTH TABS */
.month-tabs {
  display: flex;
  gap: 2px;
}

.month-tab {
  flex: 1;
  padding: 9px 4px;
  border-radius: 6px 6px 0 0;
  border: none;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 600;
  text-align: center;
  color: rgba(255,255,255,0.55);
  background: rgba(255,255,255,0.08);
  cursor: pointer;
  transition: all 0.2s;
  letter-spacing: 0.02em;
}

.month-tab:hover {
  background: rgba(255,255,255,0.15);
  color: rgba(255,255,255,0.85);
}

.month-tab.active {
  background: var(--light);
  color: var(--navy);
  font-weight: 700;
}

/* CARD FEED */
.card-feed {
  flex: 1;
  overflow-y: auto;
  padding: 12px 12px 20px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
}

.card-feed::-webkit-scrollbar { width: 4px; }
.card-feed::-webkit-scrollbar-track { background: transparent; }
.card-feed::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

/* DAY CARD */
.day-card {
  background: var(--white);
  border-radius: 12px;
  padding: 13px 14px;
  box-shadow: 0 1px 6px rgba(0,43,69,0.07);
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.card-date {
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--navy);
  letter-spacing: -0.01em;
}

.card-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
}

.cal-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 4px 11px;
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 600;
  white-space: nowrap;
  color: #ffffff;
}
.badge-post    { background: #00A9E0; }
.badge-digital { background: #00549F; }
.badge-print   { background: #F0AB00; color: #3a2800; }
.badge-video   { background: #D52B1E; }

.card-notes {
  font-size: 0.9rem;
  color: var(--text);
  line-height: 1.45;
}

.card-orders {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.order-btn {
  display: inline-flex;
  align-items: center;
  padding: 5px 14px;
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 600;
  white-space: nowrap;
  background: var(--navy);
  color: #ffffff;
  text-decoration: none;
  transition: background 0.15s;
}
.order-btn:hover { background: var(--blue); }

/* divider between badges+notes and orders */
.card-divider {
  height: 1px;
  background: var(--border);
  margin: 0 -2px;
}
</style>
