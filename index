<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Upcoming Holidays</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    width: 467px;
    height: 434px;
    overflow: hidden;
    font-family: 'Segoe UI', sans-serif;
    background: transparent;
    color: #002B45;
  }

  .widget {
    width: 467px;
    height: 434px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0,43,69,0.12);
  }

  .header { background: #002B45; padding: 10px 14px 0; flex-shrink: 0; }
  .header h1 { font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #00A9E0; margin-bottom: 8px; }
  .tabs { display: flex; gap: 2px; }
  .tab { flex: 1; padding: 7px 4px; font-size: 11px; font-weight: 600; letter-spacing: 0.04em; text-align: center; cursor: pointer; border: none; border-radius: 4px 4px 0 0; background: #004f7c; color: #cce8f4; transition: background 0.15s; text-transform: uppercase; font-family: 'Segoe UI', sans-serif; }

  .content { flex: 1; overflow: hidden; position: relative; background: #f4f8fb; }
  .panel { display: none; height: 100%; overflow-y: auto; padding: 10px 14px 8px; scrollbar-width: thin; scrollbar-color: #c5d8e8 transparent; }
  .panel::-webkit-scrollbar { width: 4px; }
  .panel::-webkit-scrollbar-track { background: transparent; }
  .panel::-webkit-scrollbar-thumb { background: #c5d8e8; border-radius: 2px; }
  .panel.active { display: block; }

  .entry { display: flex; align-items: flex-start; gap: 9px; padding: 5px 0; border-bottom: 1px solid #ddeaf3; }
  .entry:last-child { border-bottom: none; }
  .date-col { flex-shrink: 0; width: 72px; }
  .date-num { font-size: 12px; font-weight: 700; color: #0073CF; line-height: 1.2; }
  .date-day { font-size: 9.5px; color: #6b8fa8; font-weight: 500; text-transform: uppercase; letter-spacing: 0.04em; }
  .entry-text { font-size: 11.5px; line-height: 1.35; color: #002B45; padding-top: 1px; }

  .tag { display: inline-block; font-size: 9px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 1px 5px; border-radius: 2px; margin-left: 4px; vertical-align: middle; }
  .tag-federal   { background: #002B45; color: #fff; }
  .tag-marketing { background: #F0AB00; color: #002B45; }
  .tag-social    { background: #00A9E0; color: #fff; }
  .tag-order { background: #002B45; color: #fff; text-decoration: none; cursor: pointer; transition: background 0.15s; }
  .tag-order:hover { background: #0073CF; }
</style>
</head>
<body>
<div class="widget">
  <div class="header">
    <h1>Upcoming Holidays &amp; Key Dates</h1>
    <div class="tabs" id="tabBar">
      <button class="tab" data-panel="jun">June</button>
      <button class="tab" data-panel="jul">July</button>
      <button class="tab" data-panel="aug">August</button>
      <button class="tab" data-panel="sep">September</button>
    </div>
  </div>

  <div class="content">

    <!-- JUNE -->
    <div class="panel" id="panel-jun">
      <div class="entry">
        <div class="date-col"><div class="date-num">Jun 1</div><div class="date-day">Monday</div></div>
        <div class="entry-text">Last Day to Order Print Marketing for Father's Day <span class="tag tag-marketing">Print</span> <a class="tag tag-order" href="mailto:MarketingTicket@dasacquisition.com?subject=Father%27s%20Day%20Print%20Marketing%20Order">Order</a></div>
      </div>
      <div class="entry">
        <div class="date-col"><div class="date-num">Jun 4</div><div class="date-day">Thursday</div></div>
        <div class="entry-text">National Homeownership Month begins <span class="tag tag-social">Social</span></div>
      </div>
      <div class="entry">
        <div class="date-col"><div class="date-num">Jun 7</div><div class="date-day">Sunday</div></div>
        <div class="entry-text">Summer Is in 2 Weeks — Order Seasonal Marketing <span class="tag tag-marketing">Print</span> <a class="tag tag-order" href="mailto:MarketingTicket@dasacquisition.com?subject=Summer%20Seasonal%20Marketing%20Print%20Order">Order</a></div>
      </div>
      <div class="entry">
        <div class="date-col"><div class="date-num">Jun 19</div><div class="date-day">Friday</div></div>
        <div class="entry-text">Juneteenth <span class="tag tag-federal">Federal</span></div>
      </div>
      <div class="entry">
        <div class="date-col"><div class="date-num">Jun 20</div><div class="date-day">Saturday</div></div>
        <div class="entry-text">Last Day to Order Print Marketing for July 4 <span class="tag tag-marketing">Print</span> <a class="tag tag-order" href="mailto:MarketingTicket@dasacquisition.com?subject=July%204th%20Print%20Marketing%20Order">Order</a></div>
      </div>
      <div class="entry">
        <div class="date-col"><div class="date-num">Jun 21</div><div class="date-day">Sunday</div></div>
        <div class="entry-text">Father's Day <span class="tag tag-federal">Holiday</span></div>
      </div>
    </div>

    <!-- JULY -->
    <div class="panel" id="panel-jul">
      <div class="entry">
        <div class="date-col"><div class="date-num">Jul 4</div><div class="date-day">Saturday</div></div>
        <div class="entry-text">Independence Day <span class="tag tag-federal">Federal</span></div>
      </div>
      <div class="entry">
        <div class="date-col"><div class="date-num">Jul 11</div><div class="date-day">Friday</div></div>
        <div class="entry-text">National Swimming Pool Day <span class="tag tag-social">Social</span></div>
      </div>
      <div class="entry">
        <div class="date-col"><div class="date-num">Jul 19</div><div class="date-day">Saturday</div></div>
        <div class="entry-text">Order Back-To-School Season Marketing <span class="tag tag-marketing">Print</span> <a class="tag tag-order" href="mailto:MarketingTicket@dasacquisition.com?subject=Back-To-School%20Season%20Print%20Marketing%20Order">Order</a></div>
      </div>
      <div class="entry">
        <div class="date-col"><div class="date-num">Jul 28</div><div class="date-day">Monday</div></div>
        <div class="entry-text">Reorder Buyer and Seller Packets if Running Low <span class="tag tag-marketing">Print</span> <a class="tag tag-order" href="mailto:MarketingTicket@dasacquisition.com?subject=Buyer%20and%20Seller%20Packets%20Reorder">Order</a></div>
      </div>
    </div>

    <!-- AUGUST -->
    <div class="panel" id="panel-aug">
      <div class="entry">
        <div class="date-col"><div class="date-num">Aug 1</div><div class="date-day">Friday</div></div>
        <div class="entry-text">Order Monthly EDDM/Postcard Campaign <span class="tag tag-marketing">Print</span> <a class="tag tag-order" href="mailto:MarketingTicket@dasacquisition.com?subject=Monthly%20EDDM%2FPostcard%20Campaign%20Print%20Order">Order</a></div>
      </div>
      <div class="entry">
        <div class="date-col"><div class="date-num">Aug 7</div><div class="date-day">Friday</div></div>
        <div class="entry-text">Order Custom Campaign Package <span class="tag tag-marketing">Print</span> <a class="tag tag-order" href="mailto:MarketingTicket@dasacquisition.com?subject=Custom%20Campaign%20Package%20Print%20Order">Order</a></div>
      </div>
      <div class="entry">
        <div class="date-col"><div class="date-num">Aug 19</div><div class="date-day">Wednesday</div></div>
        <div class="entry-text">Order Print Marketing for Labor Day (Sep 7) <span class="tag tag-marketing">Print</span> <a class="tag tag-order" href="mailto:MarketingTicket@dasacquisition.com?subject=Labor%20Day%20Print%20Marketing%20Order">Order</a></div>
      </div>
      <div class="entry">
        <div class="date-col"><div class="date-num">Aug 28</div><div class="date-day">Friday</div></div>
        <div class="entry-text">Last Day to Order Print Marketing for Labor Day <span class="tag tag-marketing">Print</span> <a class="tag tag-order" href="mailto:MarketingTicket@dasacquisition.com?subject=Labor%20Day%20Print%20Marketing%20Order">Order</a></div>
      </div>
    </div>

    <!-- SEPTEMBER -->
    <div class="panel" id="panel-sep">
      <div class="entry">
        <div class="date-col"><div class="date-num">Sep 4</div><div class="date-day">Friday</div></div>
        <div class="entry-text">Order Custom Campaign Package <span class="tag tag-marketing">Print</span> <a class="tag tag-order" href="mailto:MarketingTicket@dasacquisition.com?subject=Custom%20Campaign%20Package%20Print%20Order">Order</a></div>
      </div>
      <div class="entry">
        <div class="date-col"><div class="date-num">Sep 5</div><div class="date-day">Friday</div></div>
        <div class="entry-text">Order Monthly EDDM/Postcard Campaign <span class="tag tag-marketing">Print</span> <a class="tag tag-order" href="mailto:MarketingTicket@dasacquisition.com?subject=Monthly%20EDDM%2FPostcard%20Campaign%20Print%20Order">Order</a></div>
      </div>
      <div class="entry">
        <div class="date-col"><div class="date-num">Sep 7</div><div class="date-day">Monday</div></div>
        <div class="entry-text">Labor Day <span class="tag tag-federal">Federal</span></div>
      </div>
      <div class="entry">
        <div class="date-col"><div class="date-num">Sep 9</div><div class="date-day">Tuesday</div></div>
        <div class="entry-text">Fall Is in 2 Weeks — Order Seasonal Marketing <span class="tag tag-marketing">Print</span> <a class="tag tag-order" href="mailto:MarketingTicket@dasacquisition.com?subject=Fall%20Seasonal%20Marketing%20Print%20Order">Order</a></div>
      </div>
      <div class="entry">
        <div class="date-col"><div class="date-num">Sep 22</div><div class="date-day">Tuesday</div></div>
        <div class="entry-text">First Day of Fall <span class="tag tag-social">Social</span></div>
      </div>
      <div class="entry">
        <div class="date-col"><div class="date-num">Sep 30</div><div class="date-day">Wednesday</div></div>
        <div class="entry-text">Order Doorhanger Campaign for Fall <span class="tag tag-marketing">Print</span> <a class="tag tag-order" href="mailto:MarketingTicket@dasacquisition.com?subject=Fall%20Doorhanger%20Campaign%20Print%20Order">Order</a></div>
      </div>
    </div>

  </div>
</div>

<script>
  function applyContentStyles() {
    document.querySelectorAll('.date-num').forEach(function(el) { el.style.setProperty('color', '#0073CF', 'important'); });
    document.querySelectorAll('.date-day').forEach(function(el) { el.style.setProperty('color', '#6b8fa8', 'important'); });
    document.querySelectorAll('.entry-text').forEach(function(el) { el.style.setProperty('color', '#002B45', 'important'); });
    document.querySelectorAll('.tag-federal').forEach(function(el) { el.style.setProperty('color', '#ffffff', 'important'); el.style.setProperty('background', '#002B45', 'important'); });
    document.querySelectorAll('.tag-marketing').forEach(function(el) { el.style.setProperty('color', '#002B45', 'important'); el.style.setProperty('background', '#F0AB00', 'important'); });
    document.querySelectorAll('.tag-social').forEach(function(el) { el.style.setProperty('color', '#ffffff', 'important'); el.style.setProperty('background', '#00A9E0', 'important'); });
    document.querySelectorAll('.tag-order').forEach(function(el) { el.style.setProperty('color', '#ffffff', 'important'); el.style.setProperty('background', '#002B45', 'important'); });
  }

  function applyTabStyles() {
    document.querySelectorAll('.tab').forEach(function(t) {
      var active = t.classList.contains('active');
      t.style.setProperty('background', active ? '#f4f8fb' : '#004f7c', 'important');
      t.style.setProperty('color', active ? '#002B45' : '#cce8f4', 'important');
      t.style.setProperty('font-weight', active ? '700' : '600', 'important');
      t.style.setProperty('border-top', active ? '2px solid #00A9E0' : 'none', 'important');
    });
  }

  function show(id) {
    document.querySelectorAll('.panel').forEach(function(p) { p.classList.remove('active'); });
    document.querySelectorAll('.tab').forEach(function(t) { t.classList.remove('active'); });
    document.getElementById('panel-' + id).classList.add('active');
    document.querySelector('[data-panel="' + id + '"]').classList.add('active');
    applyTabStyles();
    applyContentStyles();
  }

  document.querySelectorAll('.tab').forEach(function(t) {
    t.addEventListener('click', function() { show(t.dataset.panel); });
    t.addEventListener('mouseover', function() {
      if (!t.classList.contains('active')) {
        t.style.setProperty('background', '#006aa3', 'important');
        t.style.setProperty('color', '#fff', 'important');
      }
    });
    t.addEventListener('mouseout', applyTabStyles);
  });

  document.querySelector('[data-panel="jun"]').classList.add('active');
  document.getElementById('panel-jun').classList.add('active');
  setTimeout(function() { applyTabStyles(); applyContentStyles(); }, 50);
  setTimeout(function() { applyTabStyles(); applyContentStyles(); }, 200);
  setTimeout(function() { applyTabStyles(); applyContentStyles(); }, 500);
</script>
</body>
</html>
