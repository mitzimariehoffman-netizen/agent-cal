  post:    ['badge-post',    '📱 Social Media'],
  digital: ['badge-digital', '🔗 Digital'],
  print:   ['badge-print',   '🖨 Print'],
  video:   ['badge-video',   '🎬 Video'],
};

function orderBtn(subject, label) {
  return `<a class="order-btn" href="mailto:${EMAIL}?subject=${encodeURIComponent(subject)}">${label}</a>`;
}

function renderCalendar(month) {
  const rows = calendarData[month];
  const feed = document.getElementById('cardFeed');
  feed.innerHTML = rows.map(row => {
    const badges = row.actions.map(a => `<span class="cal-badge ${badgeMap[a][0]}">${badgeMap[a][1]}</span>`).join('');
    const printBtn = row.actions.includes('print') && row.printSubject ? orderBtn(row.printSubject, 'Order Print') : '';
    const postBtn  = row.postOrder  && row.postSubject  ? orderBtn(row.postSubject,  'Order Social') : '';
    const videoBtn = row.videoOrder && row.videoSubject ? orderBtn(row.videoSubject, 'Order Video')  : '';
    const hasOrders = printBtn || postBtn || videoBtn;
    return `
    <div class="day-card">
      <div class="card-date">${row.date}</div>
      <div class="card-badges">${badges}</div>
      <div class="card-notes">${row.notes}</div>
      ${hasOrders ? `<div class="card-divider"></div><div class="card-orders">${printBtn}${postBtn}${videoBtn}</div>` : ''}
    </div>`;
  }).join('');
  feed.scrollTop = 0;
}

function switchMonth(month, el) {
  document.querySelectorAll('.month-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  renderCalendar(month);
}

